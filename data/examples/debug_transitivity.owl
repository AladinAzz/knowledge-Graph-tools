    <ds:title>2018 Social Vulnerability Index</ds:title>
    <ds:category_or_snippet>Government</ds:category_or_snippet>
    <ds:description>The 2018 Social Vulnerability Index indicates the relative vulnerability of every U.S. Census tract. Census tracts are subdivisions of counties in which the Census Bureau aggregates statistical data. The SVI ranks the tracts on 15 social factors, including unemployment, minority status, and disability, and further groups them into four related themes. Thus, every tract receives a ranking for each Census variable, each of the four themes, and an overall ranking.</ds:description>
    <ds:tags>Health, Social, Vulnerability, Tract</ds:tags>
    <ds:open_data_site>Open Data BR</ds:open_data_site>
    <foaf:document rdf:resource="https://data.brla.gov/Government/2018-Social-Vulnerability-Index/q7v5-ijjg"/>
    <ds:created>2021-07-07T00:00:00</ds:created>
  </rdf:Description>
