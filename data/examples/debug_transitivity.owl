    <ds:title>City Court Warrants</ds:title>
    <ds:category_or_snippet>Public Safety</ds:category_or_snippet>
    <ds:description>Listing of active warrants for Baton Rouge City Court. Warrants are posted to the site daily, however it may take up to 7-10 days for information processed in court to be reflected on the site. If you have questions please contact the Criminal Traffic Division via email at traffic@brgov.com or call (225) 389-5278. This lookup is not confirmation of an active warrant. All City Court warrants should be confirmed by the official court file. Please contact the City Constable's Office at 389-3889 or 389-3004 for confirmation.</ds:description>
    <ds:tags>Court, Warrants</ds:tags>
    <ds:open_data_site>Open Data BR</ds:open_data_site>
    <foaf:document rdf:resource="https://data.brla.gov/Public-Safety/City-Court-Warrants/3j5u-jyar"/>
    <ds:created>2014-12-17T00:00:00</ds:created>
