<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://test.org/onto2.owl"
         xmlns="http://test.org/onto2.owl#">

<owl:Ontology rdf:about="http://test.org/onto2.owl"/>

<owl:ObjectProperty rdf:about="#related_to">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
</owl:ObjectProperty>

<owl:Class rdf:about="#Item">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:NamedIndividual rdf:about="#i1">
  <rdf:type rdf:resource="#Item"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#i2">
  <rdf:type rdf:resource="#Item"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#i3">
  <rdf:type rdf:resource="#Item"/>
</owl:NamedIndividual>


</rdf:RDF>
